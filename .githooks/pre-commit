#!/usr/bin/env bash
# Pre-commit hook — secret scanning via gitleaks
#
# Catches real secret VALUES (JWTs, API keys, private keys) before they
# enter git history. Uses value-shape detection (not just variable names)
# so documentation referencing env var names doesn't trigger false positives.
#
# Activate for this repo (recommended):
#   git config core.hooksPath .githooks
#
# Or activate globally (all repos on this machine):
#   git config --global core.hooksPath ~/.git-hooks
#   cp .githooks/pre-commit ~/.git-hooks/pre-commit
#
# Prerequisites:
#   brew install gitleaks    # macOS
#   # or see https://github.com/gitleaks/gitleaks for other platforms
#
# Config precedence (gitleaks):
#   1. Repo root .gitleaks.toml (per-repo rules + allowlist)
#   2. Built-in default config (800+ patterns)
#
# Per-line bypass: add `gitleaks:allow` comment to the line
# Repo-level allowlist: create .gitleaks.toml or .gitleaksignore in repo root

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks not installed — skipping secret scan"
  echo "    Install: brew install gitleaks"
  echo "    Docs:    https://github.com/gitleaks/gitleaks"
  exit 0
fi

# Scan staged changes; --redact hides secret values in output
if ! gitleaks protect --staged --no-banner --redact --verbose 2>&1; then
  echo ""
  echo "🚫 COMMIT BLOCKED — gitleaks detected potential secrets."
  echo ""
  echo "Options:"
  echo "  1. Remove the secret from staged changes (best)"
  echo "  2. Add 'gitleaks:allow' comment to the line (false positive)"
  echo "  3. Allowlist in .gitleaks.toml or .gitleaksignore (repo config)"
  echo "  4. Bypass (only if certain): git commit --no-verify"
  exit 1
fi

exit 0
